# Absolute base URL for Repo 2's NestJS REST API (no trailing slash).
# Must be absolute — the widget renders inside a ChatGPT iframe with its own
# origin, so relative fetches won't reach the backend. This origin also needs
# to be allow-listed in Repo 2's `_meta.ui.csp.connectDomains` for production.
VITE_WOODPRICING_API_BASE_URL=http://localhost:3000
